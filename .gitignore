# ============================================================
# .gitignore — diabetes-bucaramanga-classification
# ============================================================

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/

# Entornos virtuales
env/
venv/
.env
.venv

# Jupyter Notebooks
.ipynb_checkpoints/
*.ipynb_checkpoints

# Datos sensibles o pesados
Datasets/*.csv
Datasets/*.xlsx
Datasets/*.json
Datasets/raw/

# Modelos guardados (archivos pesados)
Modelos Guardados/*.pkl
Modelos Guardados/*.joblib
Modelos Guardados/*.h5
Modelos Guardados/*.model

# Google Colab / Drive
*.gsheet
*.gdoc
.drive/

# Sistema operativo
.DS_Store
Thumbs.db
desktop.ini

# IDEs
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# Logs y temporales
*.log
*.tmp
*.temp
